{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "C#: WeatherForecast.Api",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/WeatherForecast.Api/bin/Debug/net10.0/WeatherForecast.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/WeatherForecast.Api",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "startDebugging",
        "name": "Chrome: WeatherForecast.Api",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Views"
      },
      "logging": {
        "moduleLoad": false
      }
    },
    {
      "name": "C#: WeatherForecast.Web",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-web",
      "program": "${workspaceFolder}/WeatherForecast.Web/bin/Debug/net10.0/WeatherForecast.Web.dll",
      "cwd": "${workspaceFolder}/WeatherForecast.Web",
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "startDebugging",
        "name": "Chrome: WeatherForecast.Web",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s"
      }
    },
    {
      "name": "Chrome: WeatherForecast.Api",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "https://localhost:7182/swagger",
      "userDataDir": "${workspaceFolder}/.tmp/chrome-api",
      "runtimeArgs": [
        "--new-window",
        "--incognito"
      ]
    },
    {
      "name": "Chrome: WeatherForecast.Web",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "https://localhost:7005",
      "userDataDir": "${workspaceFolder}/.tmp/chrome-web",
      "runtimeArgs": [
        "--new-window",
        "--incognito"
      ]
    },
    {
      "name": ".NET Core Attach",
      "type": "coreclr",
      "request": "attach"
    }
  ],
  "compounds": [
    {
      "name": "WeatherForecast Full Stack",
      "configurations": [
        "C#: WeatherForecast.Api",
        "C#: WeatherForecast.Web"
      ]
    }
  ]
}
